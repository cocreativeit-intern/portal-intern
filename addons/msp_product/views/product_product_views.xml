<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_product_form_msp_gallery" model="ir.ui.view">
        <field name="name">product.product.form.msp.gallery</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='image_1920' and hasclass('oe_avatar')]/.." position="inside">
                <div class="mt-2">
                    <div class="o_form_label">Gallery Images (Main image stays as first image)</div>
                    <field
                        name="x_msp_gallery_attachment_ids"
                        widget="many2many_binary"
                        class="o_field_widget o_field_image oe_avatar"
                        options="{'accepted_file_extensions': 'image/*'}"
                    />
                    <field name="x_msp_image_ids" mode="kanban,list,form" nolabel="1">
                        <kanban>
                            <field name="name"/>
                            <field name="image_1920"/>
                            <field name="active"/>
                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record">
                                        <div class="o_kanban_image_fill_left">
                                            <field name="image_1920" widget="image"/>
                                        </div>
                                        <div class="oe_kanban_details mt-2">
                                            <div><field name="name"/></div>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="image_1920" widget="image" options="{'size': [90, 90]}"/>
                            <field name="active"/>
                        </list>
                        <form>
                            <group>
                                <field name="sequence"/>
                                <field name="name"/>
                                <field name="image_1920" widget="image" options="{'size': [256, 256]}"/>
                                <field name="active"/>
                            </group>
                        </form>
                    </field>
                </div>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="MSP">
                </page>
            </xpath>
        </field>
    </record>
</odoo>
