<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_msp_dashboard_tree" model="ir.ui.view">
        <field name="name">msp.dashboard.list</field>
        <field name="model">msp.dashboard</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="name"/>
                <field name="quote_count"/>
                <field name="sales_count"/>
                <field name="purchase_count"/>
                <field name="customer_count"/>
                <field name="task_open_count"/>
                <field name="quote_total"/>
                <field name="sales_total"/>
            </list>
        </field>
    </record>

    <record id="view_msp_dashboard_form" model="ir.ui.view">
        <field name="name">msp.dashboard.form</field>
        <field name="model">msp.dashboard</field>
        <field name="arch" type="xml">
            <form create="false" delete="false">
                <sheet>
                    <group>
                        <group string="Operations">
                            <field name="quote_count" readonly="1"/>
                            <field name="sales_count" readonly="1"/>
                            <field name="purchase_count" readonly="1"/>
                            <field name="customer_count" readonly="1"/>
                            <field name="task_open_count" readonly="1"/>
                        </group>
                        <group string="Financial">
                            <field name="quote_total" readonly="1"/>
                            <field name="sales_total" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_msp_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">msp.dashboard</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
